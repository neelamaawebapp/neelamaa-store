rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Is the logged-in user the owner of the document?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Is the logged-in user an administrator?
    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email.matches('(?i).*admincraftstyle@gmail\\.com.*') || 
          request.auth.token.email.matches('(?i).*admin@craftstyle\\.com.*') ||
          request.auth.token.email.matches('(?i).*manishagaur1983@gmail\\.com.*') ||
          request.auth.token.email.matches('(?i).*guddu20484@gmail\\.com.*')
        );
    }

    // 1. Products Collection: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Wallets Collection: User can read their own, Admin can read/write, Owner can initialize/claim birthday reward
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.balance == 100;
      allow update: if (isOwner(userId) && request.resource.data.balance == resource.data.balance + 200 && existsAfter(/databases/$(database)/documents/wallet_transactions/birthday_$(userId))) || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Wallet Transactions: User can read their own, Admin write, Owner can create signup/birthday transaction
    match /wallet_transactions/{txId} {
      allow read: if isAuthenticated() && resource.data.walletId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.walletId == request.auth.uid && (
        (request.resource.data.amount == 100 && request.resource.data.source == "SIGNUP_BONUS") ||
        (txId == "birthday_" + request.auth.uid && request.resource.data.amount == 200 && request.resource.data.source == "BIRTHDAY_GIFT")
      );
      allow update, delete: if isAdmin();
    }

    // 4. Orders Collection: User can read/create their own, Admin has full access
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin(); // Prevent users from changing status to 'Delivered' or 'Refunded'
    }

    // 5. Return Requests: User can create/read their own, Admin has full access
    match /returnRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 6. Settings Collection: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Users Collection: Owner can read/write their own document and subcollections, Admin has full access
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 8. Notifications Collection: User can read/write their own, admin has full access
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid || isAdmin();
      allow update, delete: if isAdmin();
    }

    // 9. Browser push subscriptions: each customer can manage only their own devices.
    match /push_subscriptions/{subscriptionId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 10. Promotions Collection: Public read, Admin write
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 11. Back in Stock Subscriptions: Public create, Admin full access
    match /back_in_stock_subscriptions/{subId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
